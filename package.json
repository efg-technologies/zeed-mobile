{
  "name": "zeed-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Zeed Mobile — iOS AI browser on Expo. Phase 5 feasibility spike.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "lint": "expo lint",
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts'",
    "test:watch": "node --experimental-strip-types --test --watch 'src/**/*.test.ts'",
    "coverage": "c8 --reporter=text --reporter=json-summary --include='src/**/*.ts' --exclude='src/**/*.test.ts' node --experimental-strip-types --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-linking": "~8.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "~54.0.4",
    "@types/react": "~19.1.0",
    "c8": "^11.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
