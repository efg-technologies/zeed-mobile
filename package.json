{
  "name": "zeed-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Zeed Mobile — iOS AI browser on Expo. Phase 5 feasibility spike.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
