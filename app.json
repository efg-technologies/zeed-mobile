{
  "expo": {
    "name": "Zeed Mobile",
    "slug": "zeed-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.efgtechnologies.zeedmobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Some web pages may ask to use the camera (e.g. WebRTC video calls). Zeed forwards the request to iOS without retaining any data.",
        "NSMicrophoneUsageDescription": "Some web pages may ask to use the microphone (e.g. WebRTC video calls). Zeed forwards the request to iOS without retaining any data.",
        "NSLocationWhenInUseUsageDescription": "Some web pages may ask for location (e.g. maps). Zeed forwards the request to iOS without retaining any data.",
        "NSPhotoLibraryUsageDescription": "Some web pages may ask to attach photos in upload forms. Zeed forwards the request to iOS without retaining any data.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.efgtechnologies.zeedmobile.web",
            "CFBundleURLSchemes": ["http", "https"]
          }
        ],
        "LSApplicationQueriesSchemes": ["http", "https"]
      },
      "associatedDomains": ["applinks:zeed.run"]
    },
    "android": {
      "package": "com.efgtechnologies.zeedmobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F12"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "http" },
            { "scheme": "https" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "008d9330-f46b-454e-ae6b-6e8f7f076c85"
      }
    },
    "owner": "tsuyoshi.nagamine"
  }
}
